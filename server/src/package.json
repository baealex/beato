{
    "name": "ocean-wave-server",
    "version": "1.0.0",
    "description": "Ocean Wave server",
    "scripts": {
        "postinstall": "prisma generate --schema prisma/schema.prisma",
        "dev": "cross-env PORT=44100 ts-node script/_dev.ts",
        "dev:client": "pnpm --filter ocean-wave-client dev",
        "dev:with": "pnpm --workspace-root dev",
        "start": "cross-env PORT=44100 ts-node script/_start.ts",
        "build": "tsc",
        "build:client": "pnpm --filter ocean-wave-client build",
        "type-check": "tsc --noEmit",
        "lint": "pnpm --workspace-root exec biome lint server/src/src server/src/script server/src/cli server/src/jest.config.ts server/src/jest.setup.ts",
        "test": "DATABASE_URL=file:./test.sqlite3 ts-node script/_test.ts",
        "create-schema": "ts-node cli/create-schema.ts",
        "create-component": "ts-node cli/create-component.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/baealex/ocean-wave.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/baealex/ocean-wave/issues"
    },
    "homepage": "https://github.com/baealex/ocean-wave#readme",
    "prisma": {
        "schema": "prisma/schema.prisma"
    },
    "dependencies": {
        "@baejino/auth": "^0.1.1",
        "@prisma/client": "^5.22.0",
        "bcrypt": "^5.1.1",
        "express": "^5.2.1",
        "express-winston": "^4.2.0",
        "fluent-ffmpeg": "^2.1.3",
        "graphql-http": "^1.22.4",
        "music-metadata": "^7.14.0",
        "prisma": "^5.22.0",
        "sharp": "^0.33.5",
        "socket.io": "^4.8.3",
        "sqlite3": "^5.1.7",
        "ts-node": "^10.9.2",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@graphql-tools/schema": "^10.0.31",
        "@graphql-tools/utils": "^10.11.0",
        "@types/express": "^5.0.6",
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/jest": "^29.5.14",
        "@types/node": "^25.6.0",
        "@types/supertest": "^6.0.3",
        "cross-env": "^7.0.3",
        "jest": "^29.7.0",
        "nodemon": "^3.1.11",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3"
    }
}
