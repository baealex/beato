{
    "name": "ocean-wave",
    "private": true,
    "version": "1.0.0",
    "packageManager": "pnpm@10.25.0",
    "scripts": {
        "outdated": "pnpm -r outdated",
        "update": "pnpm -r update --save",
        "upgrade": "pnpm -r upgrade --save",
        "dev:client": "pnpm --filter ocean-wave-client dev",
        "dev:server": "pnpm --filter ocean-wave-server dev",
        "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:server\"",
        "test:metadata": "node --test tests/branding/*.test.mjs",
        "test:server": "pnpm --filter ocean-wave-server test",
        "test:client": "pnpm --filter ocean-wave-client test",
        "test:ci": "pnpm test:metadata && pnpm test:server && pnpm test:client",
        "lint": "biome lint .",
        "type-check": "pnpm --filter ocean-wave-server type-check && pnpm --filter ocean-wave-client type-check",
        "build:server": "pnpm --filter ocean-wave-server build",
        "build:client": "pnpm --filter ocean-wave-client build",
        "build": "pnpm build:server && pnpm build:client",
        "check": "pnpm lint && pnpm type-check && pnpm build",
        "start:server": "pnpm --filter ocean-wave-server start",
        "start": "pnpm build:client && pnpm start:server",
        "prepare": "node scripts/setup/install-lefthook.mjs"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "concurrently": "^9.1.2",
        "lefthook": "^2.1.6"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "@prisma/client",
            "@prisma/engines",
            "bcrypt",
            "better-sqlite3",
            "esbuild",
            "prisma",
            "sharp"
        ],
        "ignoredBuiltDependencies": [
            "lefthook"
        ]
    }
}
